{
  "name": "bp-genetics",
  "version": "0.1.0",
  "description": "Ball Python genetics calculator — Punnett square engine and gene data",
  "keywords": ["ball python", "python", "genetics", "punnett square", "morphs", "reptile"],
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "typescript": "~6.0.2"
  }
}
